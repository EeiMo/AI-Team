# ============================================================
# 团队即时投票工具 — 环境变量模板
# 使用: cp .env.example .env.production 然后编辑
# ============================================================

# ─── 应用 ──────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ─── 数据库（PostgreSQL）────────────────────────────
PG_PASSWORD=请替换为强密码
DATABASE_URL=postgresql://vote_user:${PG_PASSWORD}@pg:5432/vote_db

# ─── 缓存（Redis）───────────────────────────────────
REDIS_URL=redis://redis:6379/0
# Redis 降级阈值：连续失败 N 次后降级为内存模式
REDIS_DEGRADE_THRESHOLD=3

# ─── 飞书 OAuth SSO ──────────────────────────────────
FEISHU_APP_ID=请替换为飞书应用App ID
FEISHU_APP_SECRET=请替换为飞书应用App Secret
# 飞书 OAuth 回调地址（须在飞书开放平台安全域名中配置）
# staging: http://localhost:8443/api/auth/feishu/callback
# production: https://eeimoo.cn/api/auth/feishu/callback
FEISHU_REDIRECT_URI=https://eeimoo.cn/api/auth/feishu/callback
# OAuth state 参数有效期（秒，默认 600 = 10 分钟）
OAUTH_STATE_TTL=600

# ─── JWT（SSO 会话 token） ─────────────────────────
# ⚠️ production 务必替换为随机强密码
# 生成方法：openssl rand -hex 64
JWT_SECRET=请替换为随机64字符强密钥
# JWT 有效期（默认 24h，支持 ms 格式如 7d / 12h）
JWT_EXPIRES_IN=24h

# ─── 团队配置 ────────────────────────────────────────
# 团队总人数（用于投票完成度展示）
TEAM_TOTAL_MEMBERS=24

# ─── 备份 ────────────────────────────────────────────
BACKUP_DIR=/opt/vote-app/backups/pg
RETENTION_DAYS=7
