# ============================================================
# 团队即时投票工具 — 环境变量模板
# 使用: cp .env.example .env.production 然后编辑
# ============================================================

# ─── 应用 ──────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ─── 数据库（PostgreSQL）────────────────────────────
PG_PASSWORD=请替换为强密码
DATABASE_URL=postgresql://vote_user:${PG_PASSWORD}@pg:5432/vote_db

# ─── 缓存（Redis）───────────────────────────────────
REDIS_URL=redis://redis:6379/0
# Redis 降级阈值：连续失败 N 次后降级为内存模式
REDIS_DEGRADE_THRESHOLD=3

# ─── 飞书 OAuth SSO ──────────────────────────────────
FEISHU_APP_ID=请替换为飞书应用App ID
FEISHU_APP_SECRET=请替换为飞书应用App Secret

# ─── 团队配置 ────────────────────────────────────────
# 团队总人数（用于投票完成度展示）
TEAM_TOTAL_MEMBERS=24

# ─── 备份 ────────────────────────────────────────────
BACKUP_DIR=/opt/vote-app/backups/pg
RETENTION_DAYS=7
