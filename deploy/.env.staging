# Staging 环境变量（本机测试用，与生产隔离）
NODE_ENV=staging
PORT=3001
PG_PASSWORD=vote_dev_pass
DATABASE_URL=postgresql://vote_user:vote_dev_pass@pg:5432/vote_db
REDIS_URL=redis://redis:6379/0
FEISHU_APP_ID=cli_staging_placeholder
FEISHU_APP_SECRET=staging_secret_placeholder
TEAM_TOTAL_MEMBERS=24
REDIS_DEGRADE_THRESHOLD=3
BACKUP_DIR=/tmp/vote-backups
RETENTION_DAYS=7
JWT_SECRET=staging_jwt_secret_dev_only_2026
